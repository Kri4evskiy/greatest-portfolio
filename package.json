{
  "name": "greatest-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "node .husky/install.mjs",
    "dev": "concurrently -k -n frontend,backend -c cyan,magenta \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "\"backend\\.venv\\Scripts\\python\" -m uvicorn app.main:app --reload --app-dir backend",
    "build": "npm run build:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "check": "npm run check:frontend && npm run test:backend",
    "check:frontend": "npm --prefix frontend run check && npm --prefix frontend run typecheck",
    "lint-staged": "lint-staged",
    "test": "npm run test:backend && npm run test:e2e",
    "test:backend": "\"backend\\.venv\\Scripts\\python\" -m pytest backend/tests",
    "test:e2e": "npm --prefix frontend run test:e2e"
  },
  "lint-staged": {
    "frontend/**/*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,jsonc,css}": [
      "npm --prefix frontend exec biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
