{
  "name": "greatest-portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "prepare": "bun .husky/install.mjs",
    "dev": "concurrently -k -n frontend,backend -c cyan,magenta \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "\"backend\\.venv\\Scripts\\python\" -m uvicorn app.main:app --reload --app-dir backend",
    "build": "bun run build:frontend",
    "build:frontend": "bun run --cwd frontend build",
    "check": "bun run check:frontend && bun run test:backend",
    "check:frontend": "bun run --cwd frontend check && bun run --cwd frontend typecheck",
    "format": "bun run format:frontend",
    "format:frontend": "bun run --cwd frontend format",
    "lint-staged": "bun run --cwd frontend lint-staged",
    "test": "bun run test:backend && bun run test:e2e",
    "test:backend": "\"backend\\.venv\\Scripts\\python\" -m pytest backend/tests",
    "test:e2e": "bun run --cwd frontend test:e2e"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
